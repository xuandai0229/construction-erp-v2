DATABASE_URL="postgresql://user:password@localhost:5432/construction_erp_v2"
AUTH_SECRET="replace-with-a-long-random-secret"

# Development seed credentials (required by `npx prisma db seed` outside production)
SEED_DEV_ADMIN_PASSWORD="replace-with-a-strong-local-only-password"
SEED_DEV_TEST_PASSWORD="replace-with-a-different-strong-local-only-password"

# Production seed is fail-closed. Set ALLOW_PRODUCTION_SEED=true only for an
# explicitly approved one-time admin bootstrap, then remove/rotate these values.
ALLOW_PRODUCTION_SEED="false"
SEED_ADMIN_EMAIL="admin@example.com"
SEED_ADMIN_PASSWORD="replace-with-a-strong-one-time-password"
SEED_ADMIN_NAME="System Administrator"
SEED_ADMIN_USERNAME=""
