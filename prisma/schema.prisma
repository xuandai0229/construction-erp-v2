generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum UserRole {
  ADMIN
  DIRECTOR
  DEPUTY_DIRECTOR
  CHIEF_COMMANDER
  MANAGER
  ENGINEER
  ACCOUNTANT
  STAFF
}

enum ProjectRole {
  PROJECT_MANAGER
  SITE_COMMANDER
  CHIEF_COMMANDER
  ASSISTANT_COMMANDER
  QA_QC
  HSE
  SUPERVISOR
  VIEWER
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ContractType {
  CLIENT
  SUBCONTRACTOR
  SUPPLIER
  LABOR
}

enum ContractStatus {
  DRAFT
  ACTIVE
  COMPLETED
  TERMINATED
}

enum MaterialMovementType {
  IMPORT
  EXPORT
  TRANSFER
  RETURN
}

enum PaymentStatus {
  PENDING
  APPROVED
  PARTIAL
  PAID
  REJECTED
}

enum PaymentRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
  CANCELLED
}

enum PaymentRequestType {
  ADVANCE
  PROGRESS
  FINAL
  RETENTION
  OTHER
}

enum ApprovalRequestStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum ApprovalRequestType {
  PAYMENT
  MATERIAL
  REPORT
  CONTRACT
  CHANGE_ORDER
  OTHER
}

enum ApprovalPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SiteReportStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  REVISION_REQUESTED
  LOCKED
  CANCELLED
}

enum SiteReportType {
  DAILY
  WEEKLY
}

enum WeatherCondition {
  SUNNY
  CLOUDY
  OVERCAST
  LIGHT_RAIN
  HEAVY_RAIN
  WINDY
  STORM
  OTHER
}

enum SiteReportAttachmentKind {
  PHOTO
  FILE
}

enum WBSItemStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum MaterialRequestStatus {
  DRAFT
  REQUESTED
  SUBMITTED
  APPROVED
  REJECTED
  PROCESSING
  ISSUED
  RECEIVED
  CANCELLED
}

enum MaterialRequestPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum FieldProgressItemType {
  GROUP
  WORK
  NOTE
}

enum FieldProgressItemStatus {
  PLANNED
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}

enum FieldProgressEntryStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REVISION_REQUESTED
  CANCELLED
}

enum FieldMaterialRequestStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ISSUED
  RECEIVED
  CANCELLED
}

enum FieldMaterialPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum DocumentStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
  SUPERSEDED
}

// MODELS

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  username  String?   @unique
  password  String
  name      String
  role      UserRole  @default(STAFF)
  phone     String?
  avatar    String?
  isActive  Boolean   @default(true)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  projectMembers          ProjectMember[]
  assignedProjectMembers  ProjectMember[]         @relation("ProjectMemberAssigner")
  auditLogs               AuditLog[]
  messages                ChatMessage[]
  createdSiteReports      SiteReport[]            @relation("ReportCreator")
  approvedSiteReports     SiteReport[]            @relation("ReportApprover")
  createdWBSItems         WBSItem[]
  materialRequests        MaterialRequest[]
  approvalRequests        ApprovalRequest[]       @relation("Requester")
  approvals               ApprovalRequest[]       @relation("Approver")
  documents               Document[]
  createdPaymentRequests  PaymentRequest[]        @relation("PaymentCreator")
  approvedPaymentRequests PaymentRequest[]        @relation("PaymentApprover")
  createdFieldTemplates   FieldProgressTemplate[] @relation("FieldTemplateCreator")
  createdFieldItems       FieldProgressItem[]     @relation("FieldItemCreator")
  createdFieldEntries     FieldProgressEntry[]    @relation("FieldEntryCreator")
  approvedFieldEntries    FieldProgressEntry[]    @relation("FieldEntryApprover")
  fieldMaterialRequests   FieldMaterialRequest[]  @relation("FieldMaterialRequester")
  updatedSettings         SystemSetting[]         @relation("SettingUpdater")
  notifications           Notification[]

  @@index([email])
  @@index([username])
  @@index([createdAt])
}

model Project {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  description String?
  investor    String?
  location    String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?      @db.Decimal(19, 4)
  deletedAt   DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members                ProjectMember[]
  wbsItems               WBSItem[]
  contracts              Contract[]
  documentFolders        DocumentFolder[]
  siteReports            SiteReport[]
  siteReportLines        SiteReportLine[]
  materialMovements      MaterialMovement[]
  materialRequests       MaterialRequest[]
  paymentPlans           PaymentPlan[]
  paymentRecords         PaymentRecord[]
  paymentRequests        PaymentRequest[]
  documents              Document[]
  fieldProgressTemplates FieldProgressTemplate[]
  fieldProgressItems     FieldProgressItem[]
  fieldProgressEntries   FieldProgressEntry[]
  fieldMaterialRequests  FieldMaterialRequest[]
  projectMaterialStocks  ProjectMaterialStock[]
  materialItems          MaterialItem[]
  approvalRequests       ApprovalRequest[]
  notifications          Notification[]

  @@index([code])
  @@index([status])
  @@index([createdAt])
}

model ProjectMember {
  id           String      @id @default(cuid())
  projectId    String
  userId       String
  role         ProjectRole
  assignedById String?
  isActive     Boolean     @default(true)
  note         String?
  joinedAt     DateTime    @default(now())
  leftAt       DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  project    Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedBy User?   @relation("ProjectMemberAssigner", fields: [assignedById], references: [id])

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@index([assignedById])
}

model WBSItem {
  id               String        @id @default(cuid())
  projectId        String
  parentId         String?
  code             String
  name             String
  unit             String        @default("Lần")
  designQuantity   Decimal?      @db.Decimal(19, 4)
  description      String?
  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  progress         Decimal       @default(0) @db.Decimal(5, 2)
  budget           Decimal?      @db.Decimal(19, 4)
  status           WBSItemStatus @default(PLANNED)
  note             String?
  createdById      String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  project              Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent               WBSItem?              @relation("WBSHierarchy", fields: [parentId], references: [id])
  children             WBSItem[]             @relation("WBSHierarchy")
  createdBy            User?                 @relation(fields: [createdById], references: [id])
  siteReportLines      SiteReportLine[]
  materialRequestItems MaterialRequestItem[]

  @@unique([projectId, code])
  @@index([projectId])
  @@index([parentId])
}

model Supplier {
  id            String    @id @default(cuid())
  code          String    @unique
  name          String
  taxCode       String?
  address       String?
  phone         String?
  email         String?
  contactPerson String?
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contracts       Contract[]
  paymentRequests PaymentRequest[]

  @@index([code])
}

model Contract {
  id         String         @id @default(cuid())
  projectId  String
  supplierId String?
  contractNo String         @unique
  name       String
  type       ContractType
  status     ContractStatus @default(DRAFT)
  value      Decimal        @db.Decimal(19, 4)
  signDate   DateTime?
  startDate  DateTime?
  endDate    DateTime?
  deletedAt  DateTime?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier        Supplier?        @relation(fields: [supplierId], references: [id])
  paymentPlans    PaymentPlan[]
  paymentRequests PaymentRequest[]

  @@index([projectId])
  @@index([supplierId])
  @@index([contractNo])
}

model DocumentFolder {
  id        String    @id @default(cuid())
  projectId String
  parentId  String?
  name      String
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    DocumentFolder?  @relation("FolderHierarchy", fields: [parentId], references: [id])
  children  DocumentFolder[] @relation("FolderHierarchy")
  documents Document[]

  @@index([projectId])
  @@index([parentId])
}

model Document {
  id             String         @id @default(cuid())
  projectId      String
  folderId       String
  originalName   String
  storedName     String
  mimeType       String
  extension      String
  size           Int
  storagePath    String
  uploadedById   String
  displayName    String?
  documentType   String?
  status         DocumentStatus @default(SUBMITTED)
  metadata       Json?
  fileHash       String?
  reviewedById   String?
  reviewedAt     DateTime?
  rejectedReason String?
  version        Int            @default(1)
  deletedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  project    Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  folder     DocumentFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  uploadedBy User           @relation(fields: [uploadedById], references: [id])

  @@index([projectId])
  @@index([folderId])
  @@index([uploadedById])
  @@index([status])
  @@index([documentType])
  @@index([fileHash])
  @@index([folderId, status])
}

model SiteReport {
  id                 String            @id @default(cuid())
  reportNo           String            @unique @default(dbgenerated("gen_random_uuid()::text"))
  type               SiteReportType    @default(DAILY)
  projectId          String
  title              String?
  reportDate         DateTime
  weekStartDate      DateTime?
  weekEndDate        DateTime?
  weatherCondition   WeatherCondition?
  weatherTemperature Float?
  weatherNote        String?
  gpsLat             Float?
  gpsLng             Float?

  summary         String? @db.Text
  materials       String? @db.Text
  labor           String? @db.Text
  equipment       String? @db.Text
  quality         String? @db.Text
  issues          String? @db.Text
  recommendations String? @db.Text

  reporterName String?

  // Legacy fields
  weather       String?
  manpowerCount Int?
  equipmentNote String?
  generalNote   String?

  status         SiteReportStatus @default(DRAFT)
  createdById    String
  submittedAt    DateTime?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  deletedAt      DateTime?

  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("ReportCreator", fields: [createdById], references: [id])
  approvedBy       User?                  @relation("ReportApprover", fields: [approvedById], references: [id])
  photos           SiteReportPhoto[]
  attachments      SiteReportAttachment[]
  lines            SiteReportLine[]
  materialRequests MaterialRequest[]

  @@index([projectId])
  @@index([createdById])
  @@index([reportDate])
}

model SiteReportPhoto {
  id          String   @id @default(cuid())
  reportId    String
  storageKey  String
  description String?
  createdAt   DateTime @default(now())

  report SiteReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model SiteReportAttachment {
  id           String                   @id @default(cuid())
  reportId     String
  kind         SiteReportAttachmentKind @default(FILE)
  fileName     String
  originalName String?
  mimeType     String
  sizeBytes    Int
  storagePath  String
  publicUrl    String?
  caption      String?
  createdAt    DateTime                 @default(now())

  report SiteReport @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
}

model SiteReportLine {
  id                  String    @id @default(cuid())
  siteReportId        String
  projectId           String
  wbsItemId           String?
  fieldProgressItemId String?
  workName            String?
  workContent         String
  area                String?
  constructionCrew    String?
  unit                String?
  designQuantity      Decimal?  @db.Decimal(19, 4)
  quantityToday       Decimal   @db.Decimal(19, 4)
  quantityBefore      Decimal   @default(0) @db.Decimal(19, 4)
  quantityCumulative  Decimal   @default(0) @db.Decimal(19, 4)
  progressPercent     Decimal   @default(0) @db.Decimal(5, 2)
  note                String?
  issueNote           String?
  proposalNote        String?
  sortOrder           Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  siteReport        SiteReport         @relation(fields: [siteReportId], references: [id], onDelete: Cascade)
  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsItem           WBSItem?           @relation(fields: [wbsItemId], references: [id])
  fieldProgressItem FieldProgressItem? @relation(fields: [fieldProgressItemId], references: [id])

  @@index([siteReportId])
  @@index([projectId])
  @@index([wbsItemId])
  @@index([fieldProgressItemId])
}

model MaterialRequest {
  id            String                  @id @default(cuid())
  projectId     String
  requestNo     String                  @unique
  siteReportId  String?
  requestedById String
  requestDate   DateTime
  neededDate    DateTime?
  status        MaterialRequestStatus   @default(DRAFT)
  priority      MaterialRequestPriority @default(MEDIUM)
  note          String?
  cancelReason  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  deletedAt     DateTime?

  project     Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)
  siteReport  SiteReport?           @relation(fields: [siteReportId], references: [id])
  requestedBy User                  @relation(fields: [requestedById], references: [id])
  items       MaterialRequestItem[]
  movements   MaterialMovement[]

  @@index([projectId])
  @@index([requestNo])
  @@index([siteReportId])
  @@index([requestedById])
}

model MaterialRequestItem {
  id                   String    @id @default(cuid())
  materialRequestId    String
  wbsItemId            String?
  fieldProgressItemId  String?
  workItemNameSnapshot String?
  materialCode         String?
  materialName         String
  unit                 String
  requestedQuantity    Decimal   @db.Decimal(19, 4)
  issuedQuantity       Decimal   @default(0) @db.Decimal(19, 4)
  receivedQuantity     Decimal   @default(0) @db.Decimal(19, 4)
  remainingQuantity    Decimal   @default(0) @db.Decimal(19, 4)
  reason               String?
  note                 String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  materialRequest   MaterialRequest    @relation(fields: [materialRequestId], references: [id], onDelete: Cascade)
  wbsItem           WBSItem?           @relation(fields: [wbsItemId], references: [id])
  fieldProgressItem FieldProgressItem? @relation(fields: [fieldProgressItemId], references: [id])
  movements         MaterialMovement[]

  @@index([materialRequestId])
  @@index([wbsItemId])
  @@index([fieldProgressItemId])
}

model MaterialItem {
  id          String   @id @default(cuid())
  projectId   String
  code        String
  name        String
  unit        String
  group       String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project       Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  movements     MaterialMovement[]
  projectStocks ProjectMaterialStock[]

  @@unique([projectId, code])
  @@index([projectId])
}

model MaterialMovement {
  id                    String               @id @default(cuid())
  projectId             String
  materialItemId        String
  materialRequestId     String?
  materialRequestItemId String?
  materialCodeSnapshot  String?
  materialNameSnapshot  String?
  unitSnapshot          String?
  type                  MaterialMovementType
  quantity              Decimal              @db.Decimal(19, 4)
  unitPrice             Decimal?             @db.Decimal(19, 4)
  movementDate          DateTime
  notes                 String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialItem        MaterialItem         @relation(fields: [materialItemId], references: [id])
  materialRequest     MaterialRequest?     @relation(fields: [materialRequestId], references: [id], onDelete: SetNull)
  materialRequestItem MaterialRequestItem? @relation(fields: [materialRequestItemId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([materialItemId])
  @@index([materialRequestId])
  @@index([materialRequestItemId])
  @@index([projectId, materialItemId])
  @@index([projectId, movementDate])
  @@index([movementDate])
}

model ProjectMaterialStock {
  id             String   @id @default(cuid())
  projectId      String
  materialItemId String
  stock          Decimal  @default(0) @db.Decimal(19, 4)
  minStockLevel  Decimal  @default(0) @db.Decimal(19, 4)
  lastUpdated    DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  materialItem MaterialItem @relation(fields: [materialItemId], references: [id], onDelete: Cascade)

  @@unique([projectId, materialItemId])
  @@index([projectId])
  @@index([materialItemId])
}

model PaymentPlan {
  id          String        @id @default(cuid())
  projectId   String
  contractId  String?
  name        String
  amount      Decimal       @db.Decimal(19, 4)
  plannedDate DateTime
  status      PaymentStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  project  Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contract Contract?       @relation(fields: [contractId], references: [id])
  records  PaymentRecord[]

  @@index([projectId])
  @@index([contractId])
}

model PaymentRecord {
  id            String   @id @default(cuid())
  projectId     String
  paymentPlanId String?
  amount        Decimal  @db.Decimal(19, 4)
  paymentDate   DateTime
  referenceNo   String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  paymentPlan PaymentPlan? @relation(fields: [paymentPlanId], references: [id])

  @@index([projectId])
  @@index([paymentPlanId])
}

model PaymentRequest {
  id             String               @id @default(cuid())
  requestCode    String               @unique
  projectId      String
  title          String
  supplierId     String?
  contractId     String?
  type           PaymentRequestType   @default(OTHER)
  status         PaymentRequestStatus @default(DRAFT)
  subTotal       Decimal              @default(0) @db.Decimal(19, 4)
  vatAmount      Decimal              @default(0) @db.Decimal(19, 4)
  totalAmount    Decimal              @default(0) @db.Decimal(19, 4)
  dueDate        DateTime?
  notes          String?
  createdById    String
  approvedById   String?
  approvedAt     DateTime?
  paidAt         DateTime?
  rejectedReason String?
  deletedAt      DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  contract   Contract? @relation(fields: [contractId], references: [id])
  createdBy  User      @relation("PaymentCreator", fields: [createdById], references: [id])
  approvedBy User?     @relation("PaymentApprover", fields: [approvedById], references: [id])

  @@index([projectId])
  @@index([supplierId])
  @@index([contractId])
  @@index([createdById])
  @@index([status])
}

model ApprovalRequest {
  id           String                @id @default(cuid())
  code         String                @unique
  projectId    String
  title        String
  description  String?
  type         ApprovalRequestType   @default(OTHER)
  status       ApprovalRequestStatus @default(PENDING)
  priority     ApprovalPriority      @default(NORMAL)
  amount       Decimal?              @db.Decimal(19, 4)
  dueDate      DateTime?
  requesterId  String
  decidedById  String?
  decidedAt    DateTime?
  decisionNote String?
  sourceType   String?
  sourceId     String?
  deletedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requester User    @relation("Requester", fields: [requesterId], references: [id])
  decidedBy User?   @relation("Approver", fields: [decidedById], references: [id])

  @@index([projectId])
  @@index([requesterId])
  @@index([decidedById])
  @@index([status])
  @@index([type])
  @@index([priority])
  @@index([sourceType, sourceId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String?
  projectId String?
  type      String
  severity  String    @default("INFO") // INFO, WARNING, ERROR, SUCCESS
  title     String
  message   String?
  href      String?
  isRead    Boolean   @default(false)
  createdAt DateTime  @default(now())
  readAt    DateTime?

  user    User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([projectId, createdAt])
}

model ChatMessage {
  id        String   @id @default(cuid())
  senderId  String
  content   String
  createdAt DateTime @default(now())

  sender User @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  projectId  String?
  action     String
  entityType String
  entityId   String
  beforeData String?  @db.Text
  afterData  String?  @db.Text
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([projectId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model FieldProgressTemplate {
  id          String    @id @default(cuid())
  projectId   String
  name        String
  description String?
  status      String    @default("ACTIVE")
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("FieldTemplateCreator", fields: [createdById], references: [id])
  items            FieldProgressItem[]
  entries          FieldProgressEntry[]
  materialRequests FieldMaterialRequest[]

  @@index([projectId])
}

model FieldProgressItem {
  id               String                  @id @default(cuid())
  projectId        String
  templateId       String
  parentId         String?
  sortOrder        Int                     @default(0)
  level            Int                     @default(0)
  itemType         FieldProgressItemType   @default(WORK)
  code             String?
  categoryName     String?
  workContent      String?
  constructionCrew String?
  designQuantity   Decimal?                @db.Decimal(19, 4)
  unit             String?
  status           FieldProgressItemStatus @default(PLANNED)
  isLocked         Boolean                 @default(false)
  note             String?
  createdById      String
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  deletedAt        DateTime?

  project              Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template             FieldProgressTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  parent               FieldProgressItem?     @relation("FieldItemHierarchy", fields: [parentId], references: [id])
  children             FieldProgressItem[]    @relation("FieldItemHierarchy")
  createdBy            User                   @relation("FieldItemCreator", fields: [createdById], references: [id])
  entries              FieldProgressEntry[]
  materialRequests     FieldMaterialRequest[]
  materialRequestItems MaterialRequestItem[]
  siteReportLines      SiteReportLine[]

  @@index([projectId])
  @@index([templateId])
  @@index([parentId])
  @@index([sortOrder])
}

model FieldProgressEntry {
  id             String                   @id @default(cuid())
  projectId      String
  templateId     String
  itemId         String
  entryDate      DateTime
  quantity       Decimal                  @db.Decimal(19, 4)
  issueNote      String?
  proposalNote   String?
  note           String?
  status         FieldProgressEntryStatus @default(DRAFT)
  createdById    String
  submittedAt    DateTime?
  approvedById   String?
  approvedAt     DateTime?
  rejectedReason String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  deletedAt      DateTime?

  sourceType       String?
  sourceId         String?
  sourceLineId     String?
  sourceReportId   String?
  sourceMeta       Json?
  adjustmentReason String?

  project          Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template         FieldProgressTemplate  @relation(fields: [templateId], references: [id], onDelete: Cascade)
  item             FieldProgressItem      @relation(fields: [itemId], references: [id], onDelete: Cascade)
  createdBy        User                   @relation("FieldEntryCreator", fields: [createdById], references: [id])
  approvedBy       User?                  @relation("FieldEntryApprover", fields: [approvedById], references: [id])
  materialRequests FieldMaterialRequest[]

  @@index([projectId])
  @@index([templateId])
  @@index([itemId])
  @@index([entryDate])
  @@index([sourceType, sourceId])
  @@index([sourceReportId])
}

model FieldMaterialRequest {
  id            String                     @id @default(cuid())
  projectId     String
  templateId    String
  itemId        String
  entryId       String?
  requestDate   DateTime
  neededDate    DateTime?
  requestedById String
  status        FieldMaterialRequestStatus @default(DRAFT)
  priority      FieldMaterialPriority      @default(MEDIUM)
  note          String?
  createdAt     DateTime                   @default(now())
  updatedAt     DateTime                   @updatedAt
  deletedAt     DateTime?

  project     Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template    FieldProgressTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  item        FieldProgressItem          @relation(fields: [itemId], references: [id], onDelete: Cascade)
  entry       FieldProgressEntry?        @relation(fields: [entryId], references: [id])
  requestedBy User                       @relation("FieldMaterialRequester", fields: [requestedById], references: [id])
  items       FieldMaterialRequestItem[]

  @@index([projectId])
  @@index([templateId])
  @@index([itemId])
  @@index([entryId])
}

model FieldMaterialRequestItem {
  id                String    @id @default(cuid())
  requestId         String
  materialName      String
  unit              String
  requestedQuantity Decimal   @db.Decimal(19, 4)
  reason            String?
  note              String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  request FieldMaterialRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
}

model SystemSetting {
  id String @id @default(cuid())

  // Organization
  companyName          String
  taxCode              String
  hotline              String
  timezone             String
  currency             String
  fiscalYearStartMonth String

  // Security
  requireTwoFactorForAdmins Boolean @default(true)
  sessionTimeoutMinutes     Int     @default(60)
  passwordRotationDays      Int     @default(90)
  allowedIpMode             String  @default("restricted")
  trustedDeviceReviewDays   Int     @default(30)
  auditSensitiveActions     Boolean @default(true)

  // Workflow
  requireProjectCodeBeforeSpending Boolean @default(true)
  materialRequestApproval          Boolean @default(true)
  paymentTwoStepApproval           Boolean @default(true)
  reportLockAfterApproval          Boolean @default(true)
  contractValueThreshold           Decimal @db.Decimal(19, 4)

  // Documents
  enforceNamingConvention Boolean @default(true)
  autoVersioning          Boolean @default(true)
  allowedExtensions       String  @default("pdf, docx, xlsx, dwg, jpg, png, heic")
  maxUploadSizeMb         Int     @default(50)
  documentRetentionYears  Int     @default(10)

  // Notifications
  emailDailyDigest    Boolean @default(false)
  approvalEscalation  Boolean @default(true)
  fieldReportReminder Boolean @default(true)
  reminderTime        String  @default("17:30")
  escalationHours     Int     @default(24)

  // Data
  automaticBackup        Boolean @default(true)
  backupFrequency        String  @default("daily")
  retentionYears         Int     @default(7)
  exportRequiresApproval Boolean @default(true)
  maintenanceWindow      String  @default("22:00 - 23:00")

  // Metadata
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  version     Int      @default(1)

  updatedBy User? @relation("SettingUpdater", fields: [updatedById], references: [id])

  @@index([updatedById])
}
