  plannedStartDate    DateTime?
  status              WBSItemStatus         @default(PLANNED)
  unit                String                @default("Lần")
  MaterialRequestItem MaterialRequestItem[]
  SiteReportLine      SiteReportLine[]
  User                User?                 @relation(fields: [createdById], references: [id])
  WBSItem             WBSItem?              @relation("WBSItemToWBSItem", fields: [parentId], references: [id])
  other_WBSItem       WBSItem[]             @relation("WBSItemToWBSItem")
  Project             Project               @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, code])
  @@index([parentId])
  @@index([projectId])
}

model WorkTask {
  id                                    String                  @id
  projectId                             String
  creatorId                             String
  primaryAssigneeId                     String?
  reviewerId                            String?
  approverId                            String?
  title                                 String
  description                           String?
  priority                              String                  @default("NORMAL")
  confidentiality                       String                  @default("NORMAL")
  lifecycle                             String
  acceptance                            String
  execution                             String
  review                                String
  handover                              String
  waitingReason                         String?
  deadlineAt                            DateTime?
  progressPercent                       Int                     @default(0)
  version                               Int                     @default(1)
  snapshot                              Json
  createdAt                             DateTime                @default(now())
  updatedAt                             DateTime
  User_WorkTask_approverIdToUser        User?                   @relation("WorkTask_approverIdToUser", fields: [approverId], references: [id])
  User_WorkTask_creatorIdToUser         User                    @relation("WorkTask_creatorIdToUser", fields: [creatorId], references: [id])
  User_WorkTask_primaryAssigneeIdToUser User?                   @relation("WorkTask_primaryAssigneeIdToUser", fields: [primaryAssigneeId], references: [id])
  Project                               Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  User_WorkTask_reviewerIdToUser        User?                   @relation("WorkTask_reviewerIdToUser", fields: [reviewerId], references: [id])
  WorkTaskAction                        WorkTaskAction[]
  WorkTaskIdempotency                   WorkTaskIdempotency[]
  WorkTaskOutboxMessage                 WorkTaskOutboxMessage[]

  @@index([creatorId, updatedAt])
  @@index([lifecycle, updatedAt])
  @@index([primaryAssigneeId, updatedAt])
  @@index([projectId, updatedAt])
}

model WorkTaskAction {
  id         String   @id
  taskId     String
  action     String
  actorId    String
  version    Int
  occurredAt DateTime
  effects    Json
  createdAt  DateTime @default(now())
  User       User     @relation(fields: [actorId], references: [id])
  WorkTask   WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([actorId, occurredAt])
  @@index([taskId, occurredAt])
}

model WorkTaskIdempotency {
  id          String                   @id
  key         String
  action      String
  actorId     String
  projectId   String?
  taskId      String?
  fingerprint String
  state       WorkTaskIdempotencyState
  result      Json?
  createdAt   DateTime                 @default(now())
  completedAt DateTime?
  scopeKey    String
  WorkTask    WorkTask?                @relation(fields: [taskId], references: [id])

  @@unique([key, scopeKey])
  @@index([actorId, projectId])
  @@index([taskId])
}

model WorkTaskOutboxMessage {
  id               String   @id
  taskId           String
  action           String
  aggregateVersion Int
  idempotencyKey   String
  message          Json
  occurredAt       DateTime
  createdAt        DateTime @default(now())
  WorkTask         WorkTask @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([idempotencyKey])
  @@index([taskId, aggregateVersion])
}

