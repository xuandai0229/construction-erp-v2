model WBSItem {
  id                  String                @id
  projectId           String
  parentId            String?
  code                String
  name                String
  description         String?
  progress            Decimal               @default(0) @db.Decimal(5, 2)
  budget              Decimal?              @db.Decimal(19, 4)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  createdById         String?
  deletedAt           DateTime?
  designQuantity      Decimal?              @db.Decimal(19, 4)
  note                String?
